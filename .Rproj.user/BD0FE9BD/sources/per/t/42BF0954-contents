#' @export
edstr_view <- \(config = get(.config_name),
                config_str = with(config, str),
                data,
                text_input = "text",
                id = NULL,
                filter = NULL,
                replace = NULL,
                str = NULL,
                sample = 20,
                quantile_left = 0.75,
                quantile_right = 0.99,
                raw = FALSE,
                ...) {

if (is_character(config)) config <- get(config)
if (is_character(data)) data <- get(data)

text_input <- enexpr(text_input)
id <- enexpr(id)
filter <- enexpr(filter)

q_left <- glue("q{quantile_left*100}")
q_right <- glue("q{quantile_right*100}")
over_q_left <- str_c("over_", q_left)
over_q_right <- str_c("over_", q_right)

if (!is_null(filter)) data <- data |> filter(!!filter)
  
replace <- with(config_str, eval(enexpr(replace)))

if (!is.list(replace)) replace <- list(replace)

data <-
data |>
  mutate(!!text_input :=
           reduce(replace,
                  str_replace_all,
                  .init = get(text_input)))

data_match <-
data |>
  mutate(match = str_extract_all(data[[text_input]], str)) |>
  unnest(match) |>
  mutate(nchar = nchar(match),
         !!q_left := quantile(nchar, probs = quantile_left, na.rm = TRUE),
         !!over_q_left := ifelse(nchar > get(q_left), 1, 0),
         !!q_right := quantile(nchar, probs = quantile_right, na.rm = TRUE),
         !!over_q_right := ifelse(nchar > get(q_right), 1, 0)) |>
  select(!!id, !!text_input, match, nchar, matches("(over_)?q(\\d+)")) |>
  arrange(desc(nchar)) |>
  drop_na()

data_distinct <-
data_match |>
  count(match,
        nchar,
        !!q_left := get(q_left),
        !!over_q_left := get(over_q_left),
        !!q_right := get(q_right),
        !!over_q_right := get(over_q_right)) |>
  arrange(desc(nchar)) |>
  mutate(n = factor(n))

if (nrow(data_match) > 20) sample <- sample(nrow(data_match), 20)
else sample <- 1:nrow(data_match)

data_sample <- data_match[sample, ]

data_print <-
data_match[[text_input]][sample] |>
  str_view(str, ...)

if (raw & !is_null(filter)) {

  data_print <-
  data |>
    filter(!!filter) |>
    pull(text_input)
    
}

print(data_print)

if (!is_null(filter)) {
  
  cli_text("\n\n")
  cli_alert_info("filter ON")
  cli_text("\n\n")
  
}

data_distinct[c("match", "nchar","n")] |>
  arrange(desc(n)) |>
  print()

assign(glue("{with(config, file)}_view"),
       list(match = data_match,
            sample = data_sample,
            distinct = data_distinct),
       envir = .GlobalEnv)

median_match <-
data_match |>
  count(!!id, !!text_input) |>
  pull(n) |>
  median()

message(glue(
"{nrow(data_match)} matchs (median: {median_match} par id)
{nrow(data_distinct)} distincts\n\n"
))

if (n_distinct(data_match$nchar) >= 100) {

    message(glue(
    "nchar:
    > {q_left}: {nrow(data_match[data_match[[over_q_left]] == 1, ])}
    > {q_right}: {nrow(data_match[data_match[[over_q_right]] == 1, ])}\n\n"
    ))

    print(data_match[data_match[[over_q_left]] == 1, ] |>
            ggplot(aes(nchar)) +
            geom_density(color = "skyblue",
                         fill = "skyblue") +
            geom_vline(aes(xintercept = get(q_left)),
                       color = "blue", linewidth = 1.5) +
            geom_vline(aes(xintercept = get(q_right)),
                       color = "red", linewidth = 1.5))

    }

}


#' @export
edstr_extract <- \(config = get(.config_name),
                   config_str = with(config, str),
                   data = glue("{with(config, file)}_clean"),
                   sample = NULL,
                   filter = NULL,
                   exclus_uf_code = list(var = "", code = "\\t"),
                   exclus_uf_libelle = list(var = "", libelle = "\\t"),
                   llm = NULL,
                   text_input = "text",
                   split,
                   replace = NULL,
                   join_by, 
                   group_by,
                   extra_cols = NULL,
                   ngrams,
                   nchar_max = 8000,
                   str,
                   upper_only = NA,
                   str_suppl = "\\t", 
                   limits = "both",
                   exclus_man = "\\t", 
                   exclus_auto_except = NA, 
                   highlight_bg = "#ffffff", 
                   highlight_color = "red",
                   dir_suffix = sample,
                   filename_suffix = sample) {

if (is_character(config)) config <- get(config)
if (is_character(data)) data <- get(data)

filter <- enexpr(filter)
exclus_uf_code <- enexpr(exclus_uf_code)
exclus_uf_libelle <- enexpr(exclus_uf_libelle)
llm <- enexpr(llm)

cli_h1("edstr_extract")
cli_text("\n\n")

#--- SAVE PARAMS ---------------------------------------------------------------------------------

dir_name <- glue("{with(config, file)}_extract")
save_dir <- glue("{with(config, dir)}/{dir_name}")
save_files <- dir_name

if (!is_null(dir_suffix)) save_dir <- glue("{save_dir}_{dir_suffix}")

if (!is_null(filename_suffix)) save_files <- glue("{dir_name}_{filename_suffix}")

if (!file.exists(glue(save_dir))) dir.create(path = glue(save_dir))

.save_extract <- glue("{save_dir}/{save_files}")

.lib <- glue("{save_dir}/lib")
if (exists(.lib)) unlink(.lib, recursive = TRUE)

#--- FILTERS -------------------------------------------------------------------------------------

data_total <- data

if (!is.null(sample)) { 
  
  data <- data[sample(nrow(data), sample), ]
  
  cli_alert_info("sample: {sample}")
  
  if (is.null(filter)) cli_text("\n\n")
  
} else sample <- nrow(data_total)

if (!is.null(filter)) {
  
  data <- data |> filter(!!filter)
  
  cli_alert_info("filter ON")
  cli_text("\n\n")
   
}

data_exclus_uf <-
data |>
  filter(str_detect(!!exclus_uf_code$var, !!exclus_uf_code$code)
         | str_detect(!!exclus_uf_libelle$var, !!exclus_uf_libelle$libelle)) |>
  count(code_uf_entree, libelle_uf_entree, sort = TRUE) |>
  mutate(prop = round(n/nrow(data), 3))

data <-
data |>
  filter(!str_detect(!!exclus_uf_code$var, !!exclus_uf_code$code)) |>
  filter(!str_detect(!!exclus_uf_libelle$var, !!exclus_uf_libelle$libelle))

n_uf <- NA

if (exclus_uf_code$var != "" & exclus_uf_libelle$var == "") n_uf <- n_distinct(data[[exclus_uf_code$var]])
if (exclus_uf_code$var == "" & exclus_uf_libelle$var != "") n_uf <- n_distinct(data[[exclus_uf_libelle$var]])
if (exclus_uf_code$var != "" & exclus_uf_libelle$var != "") n_uf <- n_distinct(data[[exclus_uf_code$var]])

if (!is_null(llm)) {

  llm_filter <-
  read_csv(glue(llm$filename)) |>
    filter(!!llm$filter) |>
    pull(!!llm$select)

  data <- data |> filter(!!llm$select %in% llm_filter)

}

#--- SPLIT -------------------------------------------------------------------------------------

cli_progress_step("{.strong step 1:} split & replace")

data_split <-
data |>
  unnest_tokens(output = !!text_input,
                input = !!text_input,
                token = str_split,
                pattern = str_u(with(config_str, eval(enexpr(split)))),
                to_lower = FALSE) |>
  mutate(!!text_input :=
           reduce(with(config_str, !!enexpr(replace)), 
                  str_replace_all,
                  .init = get(text_input)))

cli_progress_done()

#--- LOWER, DEPUNCT AND TOKENIZE --------------------------------------------------------------------------------------------

cli_progress_step("{.strong step 2:} lower, depunct & tokenize")

data_clean <-
data_split |>
  mutate(!!text_input := iconv(get(text_input), from = "UTF-8", to = "ASCII//TRANSLIT"))

.ngrams <-
ngrams |>
  map(~ data_clean |>
        unnest_tokens(output = !!text_input,
                      input = !!text_input,
                      token = "ngrams",
                      n = .) |>
        distinct())

if (!is_list(str)) str <- as.list(c("<concept>" = str))

lim <- \(start, end) glue("{start}({str_u(str)}){end}")

switch(limits,
       "start" = .cpts_str <- lim("^", ""),
       "end" = .cpts_str <- lim("", "$"),
       "both" = .cpts_str <- lim("^", "$"))

.cpts_names <- str_c(names(str), collapse = ", ")

.split <-
seq_along(ngrams) |>
  map(~ .ngrams[[.]] |>
        filter(str_detect(get(text_input), .cpts_str)) |>
        count(!!.cpts_names := get(text_input), sort = TRUE))

.match <-
map2(.x = seq_along(ngrams),
     .y = ngrams,
     ~ .ngrams[[.x]][c(group_by, join_by, text_input)] |>
        mutate(ngrams = .y) |>
        filter(get(text_input) %in% c(.split[[.]][[!!.cpts_names]])))

data_match <- bind_rows(.match)

if (nrow(data_match) == 0) cli_abort("No results")

cli_progress_done()

#--- LIST EXCLUSIONS ------------------------------------------------------------------------------------------

cli_progress_step("{.strong step 3:} set exclusion lists")

str_exclus <-
data_match[text_input] |>
  filter(!str_detect(text, glue("^({str_u(exclus_auto_except)})$"))) |>
  distinct() |>
  pull()

str_exclus_bb <- glue("\\b{str_exclus}\\b")
str_exclus_.sb <- glue(".\\s{str_exclus}\\b")

data_exclus <- data_match |> select(all_of(text_input), ngrams) |> distinct()

exclus_auto_start <-
map2_df(.x = str_exclus_bb,
        .y = str_exclus,
        ~ data_exclus |>
          filter(str_starts(get(text_input), .x) & !str_ends(get(text_input), .x)) |>
          mutate(start_match = .y))

exclus_auto_end <-
map2_df(.x = str_exclus_bb,
        .y = str_exclus,
        ~ data_exclus |>
          filter(!str_starts(get(text_input), .x) & str_ends(get(text_input), .x)) |>
          mutate(end_match = .y))

exclus_auto_both <-
pmap_df(list(str_exclus_bb,
             str_exclus_.sb,
             str_exclus),
        ~ data_exclus |>
          filter(str_starts(get(text_input), ..1) & str_ends(get(text_input), ..2)) |>
          mutate(both_match = ..3))

data_exclus_auto <-
exclus_auto_start |>
  full_join(exclus_auto_end,
            by = c(text_input, "ngrams"),
            relationship = "many-to-many") |>
  full_join(exclus_auto_both,
            by = c(text_input, "ngrams"),
            relationship = "many-to-many")

if (nrow(data_exclus_auto) > 0) {

  data_exclus_auto <-
  data_exclus_auto |>
    filter(!str_detect(end_match, str_u(data_exclus_auto[[text_input]])) | is.na(end_match)) |>
    filter(!str_detect(start_match, str_u(data_exclus_auto[[text_input]])) | is.na(start_match))

}  

data_match_final <-
data_match |> 
  anti_join(data_exclus_auto[text_input], by = text_input)

data_exclus_man <-
data_match_final |>
  filter(str_detect(get(text_input), str_u(exclus_man)))

data_match_final <-
data_match_final |>
  anti_join(data_exclus_man[text_input], by = text_input)

cli_progress_done()

#--- EXTRACT --------------------------------------------------------------------------------------------------

cli_progress_step("{.strong step 4:} extract")

data_id <-
names(str) |>
  map(~ data_match_final |>
        mutate(concept = ifelse(str_starts(get(text_input), str_u(str[[.]])), ., NA))) |>
  bind_rows() |>
  drop_na()

data_count <-
data_id |>
  count(!!text_input := get(text_input), concept, ngrams, sort = TRUE)

data_extract <-
data_count[[text_input]] |>
  str_replace_all(glue("\\b{upper_only}\\b"), glue("(?-i){toupper(upper_only)}"))

data_extract <-
str_c("(?i)\\b",
      str_c(data_extract, collapse = "\\b|(?i)\\b"),
      "\\b") |>
  str_replace_all("e|(?<=m(a|i)cro)\\s", ".") |>
  str_replace_all("\\sa\\s", " . ")

.cpts_label <- str_unique(data_id$concept)

.rows <-
list(str = data_extract,
     str_suppl = str_suppl) |>
map(~ data_clean[[text_input]] |>
      str_detect(.) |>
      which())

data_str_br_db <-
data_split[sort(c(.rows$str_suppl, .rows$str)), ] |>
  inner_join(data_id[names(data_id) != text_input],
             by = c(join_by, group_by),
             relationship = "many-to-many") |>
  select(all_of(c(join_by, group_by, extra_cols, text_input)), concept) |>
  distinct() |>
  pivot_wider(names_from = concept, values_from = concept) |>
  mutate(across(any_of(.cpts_label), ~ ifelse(!is.na(.), 1, NA))) |>
  group_by(!!join_by := get(join_by)) |>
  mutate(n_row = seq_along(text_input)) |>
  fill(starts_with(.cpts_label),
       .direction = "updown") |>
  mutate(!!text_input := get(text_input) |> str_flatten("<br><br>"),
         across(starts_with(.cpts_label), ~ replace_na(., 0)),
         nchar = nchar(get(text_input))) |>
  ungroup() |>
  select(-n_row) |>
  filter(!is.na(get(group_by))) |>
  distinct()

data_exclus_nchar <-
data_str_br_db[c("text", "nchar")] |>
  filter(nchar > nchar_max)

data_str_br <-
data_str_br_db |>
  group_by(!!group_by := get(group_by),
           !!text_input := get(text_input)) |>
  filter(!duplicated(get(text_input)),
         nchar <= nchar_max) |>
  ungroup()

data_str_cat <-
data_str_br |>
  mutate(!!text_input := str_replace_all(get(text_input), "<br><br>", " "))

data_str_split <-
data_str_cat |>
  separate_rows(all_of(text_input), sep = "(?<=\\.)\\s")

cli_progress_done()

#--- SUMMARIZE AND SET FINAL LIST --------------------------------------------------------------------------------------------------

cli_progress_step("{.strong step 5:} summarize & set final list")

summary_cols <-
list(match = data_match,
     exclus_auto = data_exclus_auto,
     exclus_man = data_exclus_man,
     retenu = data_id,
     distinct = data_count)

data_summary <-
map2(.x = summary_cols,
     .y = names(summary_cols),
     ~ .x |>
       group_by(ngrams) |>
       count(name = .y))

data_summary <-
seq(summary_cols) |>
  map_df(~ tibble(ngrams = ngrams) |>
           left_join(data_summary[[.]], by = "ngrams")) |>
  group_by(ngrams) |>
  fill(names(summary_cols), .direction = "updown") |>
  distinct()

data_match_list <-
list(data = data,
     split = data_split,
     match = data_match,
     id = data_id,
     count = data_count,
     extract = data_extract,
     str = list(br = data_str_br,
                cat = data_str_cat,
                split = data_str_split),
     exclusions = list(auto = data_exclus_auto,
                       man = data_exclus_man,
                       uf = data_exclus_uf,
                       nchar = data_exclus_nchar),
     summary = data_summary)

assign(glue(save_files), data_match_list, envir = .GlobalEnv)

cli_progress_done()

#--- PRINT -------------------------------------------------------------------------------------------------

print_query <-
map2(.x = names(str),
     .y = seq(str),
     ~ list2(!!.x := glue("^({str_u(str[.y])})$"))) |>
  unlist()

print_concept <-
list(data_id, data_count) |>
  map(~ . |>
        group_by(concept) |>
        count() |> 
        ungroup())

print_group <-
data_id |>
  group_by(concept) |>
  mutate(!!group_by := n_distinct(get(group_by))) |>
  ungroup() |>
  distinct(concept, !!group_by := get(group_by))

print_concept <-
inner_join(print_concept[[1]] |> rename(match = n),
           print_concept[[2]] |> rename(distinct = n),
           by = "concept") |>
  inner_join(print_group, by = "concept")

print(list(ngram = .split,
           query = print_query,
           str = print_concept,
           exclus_auto = data_exclus_auto,
           exclus_man = data_exclus_man,
           exclus_uf = data_exclus_uf,
           summary = data_summary))

message(glue(
"n total: {n <- nrow(data_total)} obs.
n sample: {sample} obs. ({round(sample/n*100, 1)}% total)
