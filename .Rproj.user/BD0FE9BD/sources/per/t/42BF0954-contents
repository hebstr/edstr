      str_view() |>
      print()

    query <-
    query |>
      read_lines() |> 
      str_replace_all(c("$" = " ")) |>
      str_flatten()

  }

  if (!is_null(head)) {
    
    query <- glue("{query} FETCH FIRST {head} ROWS ONLY")
    
  }
  
  data_import <-
  .con |>
    tbl(sql(query)) |>
    collect() |>
    set_names(tolower)
  
  assign(glue("{config_file}_import"), data_import, envir = .GlobalEnv)


    
  cli_progress_step("save {.strong {config_file}_import}")
  
  save(list = glue("{config_file}_import"),
