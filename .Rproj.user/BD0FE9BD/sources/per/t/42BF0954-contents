{n_distinct(data_match[[text_input]])} expressions distinctes
{nrow(data_exclus_auto)} exclusions auto
{nrow(data_exclus_man)} exclusions manuelles
{db <- nrow(data_str_br_db) - nrow(data_str_br)} doublons ({round(db/nrow(data_str_br_db)*100, 1)}% base)
{nrow(data_exclus_nchar)} extraits > {nchar_max} chr

soit:
{nrow(data_id)} matchs pour {ni <- n_distinct(data_str_br[[v]])} {v} ({round(ni/nt*100, 1)}% base)
{nrow(data_count)} expressions distinctes pour {n_distinct(data_count$concept)} concepts
{n_distinct(data_str_br[[group_by]])} {group_by}\n\n"
))

if (length(unique(data_count$ngrams)) > 1) {

  print(data_count |>
          ggplot(aes(x = ngrams, y = n)) +
